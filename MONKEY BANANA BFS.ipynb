from collections import deque

PLACES = ["door", "window", "center"]

INITIAL_STATE = ("door", "window", "floor", False)

GOAL_STATE = lambda s: s[3] == True


def get_actions(state):
    actions = []
    m, b, on, has = state


    if on == "floor":
        for p in PLACES:
            if p != m:
                actions.append(("walk", p))


    if m == b and on == "floor":
        for p in PLACES:
            if p != m:
                actions.append(("push", p))


    if m == b and on == "floor":
        actions.append(("climb", None))


    if m == "center" and b == "center" and on == "box" and not has:
        actions.append(("grab", None))

    return actions


def apply_action(state, action):
    m, b, on, has = state
    name, target = action

    if name == "walk":
        return (target, b, "floor", has)

    if name == "push":
        return (target, target, "floor", has)

    if name == "climb":
        return (m, b, "box", has)

    if name == "grab":
        return (m, b, on, True)


def solve():
    queue = deque()
    queue.append((INITIAL_STATE, []))
    visited = set()

    while queue:
        state, plan = queue.popleft()

        if state in visited:
            continue

        visited.add(state)

        if GOAL_STATE(state):
            return plan, state

        for action in get_actions(state):
            new_state = apply_action(state, action)
            queue.append((new_state, plan + [action]))

    return None, None


if __name__ == "__main__":
    plan, final_state = solve()

    print("Initial state:", INITIAL_STATE)
    print("\nPlan:\n")

    for step in plan:
        if step[1]:
            print(f"{step[0]} -> {step[1]}")
        else:
            print(step[0])

    print("\nFinal state:", final_state)
     
Initial state: ('door', 'window', 'floor', False)

Plan:

walk -> window
push -> center
climb
grab

Final state: ('center', 'center', 'box', True)
